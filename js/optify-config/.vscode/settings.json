{
	"editor.codeActionsOnSave": {
		"source.fixAll.oxc": "always"
	},
	// Avoid issues with napi macros.
	"rust-analyzer.procMacro.ignored": { "napi-derive": ["napi"] },
	"[json]": {
		"editor.formatOnSave": true
	},
	"[jsonc]": {
		"editor.formatOnSave": true
	},
	"[markdown]": {
		"editor.formatOnSave": true
	},
	"[rust]": {
		"editor.formatOnSave": true
	},
	"[typescript]": {
		"editor.formatOnSave": true
	},
	"cSpell.words": ["napi", "threadsafe"]
}
