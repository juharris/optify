# Required due to conflicting peer dependencies:
# - @textea/json-viewer@4.0.1 requires react@^17||^18
# - reagraph@4.30.8 depends on @react-three/fiber@^9.5.0
# - @react-three/fiber@^9.5.0 requires react@>=19
# These packages are incompatible at the peer dependency level but work correctly
# at runtime, so legacy-peer-deps allows installation to proceed.
legacy-peer-deps=true
